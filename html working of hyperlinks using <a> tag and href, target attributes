<!DOCTYPE html>
<html>
<head>
    <title>Hyperlinks Example</title>
</head>
<body>

    <h1>HTML Hyperlinks Demonstration</h1>

    <!-- Text Link -->
    <h2>Text Link</h2>
    <p>
        Click the link below to visit AEC website:
    </p>
    <a href="https://www.aec.edu.in/" target="_blank">
        Visit AEC Website
    </a>

    <!-- Image Link -->
    <h2>Image Link</h2>
    <p>
        Click the image below to visit AEC Gallery:
    </p>
    <a href="https://www.aec.edu.in/?p=Gallery" target="_blank">
        <img src="https://via.placeholder.com/200" alt="AEC Gallery Image" width="200" height="150">
    </a>

</body>
</html>
