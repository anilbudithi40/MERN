<!DOCTYPE html>
<html>
<head>
    <title>HTML Lists Example</title>
</head>
<body>

    <h1>HTML Lists Demonstration</h1>

    <!-- Ordered List -->
    <h2>Ordered List</h2>
    <ol>
        <li>HTML</li>
        <li>CSS</li>
        <li>JavaScript</li>
    </ol>

    <!-- Unordered List -->
    <h2>Unordered List</h2>
    <ul>
        <li>Apple</li>
        <li>Banana</li>
        <li>Mango</li>
    </ul>

    <!-- Nested List -->
    <h2>Nested List</h2>
    <ul>
        <li>Programming Languages
            <ul>
                <li>Python</li>
                <li>Java</li>
                <li>C++</li>
            </ul>
        </li>
        <li>Web Technologies
            <ul>
                <li>HTML</li>
                <li>CSS</li>
            </ul>
        </li>
    </ul>

    <!-- Ordered List inside Unordered List -->
    <h2>Ordered List inside Unordered List</h2>
    <ul>
        <li>Steps to Create a Web Page:
            <ol>
                <li>Open Text Editor</li>
                <li>Write HTML Code</li>
                <li>Save with .html extension</li>
                <li>Open in Browser</li>
            </ol>
        </li>
    </ul>

    <!-- Definition List -->
    <h2>Definition List</h2>
    <dl>
        <dt>HTML</dt>
        <dd>HyperText Markup Language used to create web pages.</dd>

        <dt>CSS</dt>
        <dd>Style sheet language used for designing web pages.</dd>

        <dt>JavaScript</dt>
        <dd>Programming language used to make web pages interactive.</dd>
    </dl>

</body>
</html>
