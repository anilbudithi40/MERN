<!DOCTYPE html>
<html>
<head>
    <title>HTML Tables Example</title>
</head>
<body>

    <h1>Student Table</h1>

    <table border="1">
        <tr>
            <th rowspan="2">Name</th>
            <th colspan="2">Marks</th>
        </tr>
        <tr>
            <th>Math</th>
            <th>Science</th>
        </tr>
        <tr>
            <td>John</td>
            <td>85</td>
            <td>90</td>
        </tr>
        <tr>
            <td>Emma</td>
            <td>88</td>
            <td>92</td>
        </tr>
    </table>

</body>
</html>
