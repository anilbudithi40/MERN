<!DOCTYPE html>
<html>
<head>
    <title>Combinator Selectors</title>
    <style>
        /* Descendant selector */
        div p { color: blue; }

        /* Child selector */
        div > h3 { color: red; }

        /* Adjacent sibling */
        h1 + p { color: green; }

        /* General sibling */
        h2 ~ p { color: orange; }
    </style>
</head>
<body>

<div>
    <h3>Child Selector Example</h3>
    <p>Descendant paragraph</p>
</div>

<h1>Heading 1</h1>
<p>Adjacent sibling paragraph</p>

<h2>Heading 2</h2>
<p>General sibling paragraph 1</p>
<p>General sibling paragraph 2</p>

</body>
</html>
