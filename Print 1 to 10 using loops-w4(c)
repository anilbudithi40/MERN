<!DOCTYPE html>
<html>
<head>
    <title>Loops Example</title>
</head>
<body>

<h1>Print 1 to 10</h1>

<h2>Using for loop</h2>
<script>
    for (let i = 1; i <= 10; i++) {
        document.write(i + " ");
    }

    document.write("<br><br>");

    document.write("<h2>Using while loop</h2>");
    let j = 1;
    while (j <= 10) {
        document.write(j + " ");
        j++;
    }

    document.write("<br><br>");

    document.write("<h2>Using do-while loop</h2>");
    let k = 1;
    do {
        document.write(k + " ");
        k++;
    } while (k <= 10);
</script>

</body>
</html>
